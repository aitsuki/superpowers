#!/usr/bin/env bash
# SessionStart hook for powerset plugin

set -euo pipefail

# Determine plugin root directory
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Read using-powerset content
using_powerset_content=$(cat "${PLUGIN_ROOT}/skills/using-powerset/SKILL.md" 2>&1 || echo "Error reading using-powerset skill")

# Escape string for JSON embedding using bash parameter substitution.
# Each ${s//old/new} is a single C-level pass - orders of magnitude
# faster than the character-by-character loop this replaces.
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

using_powerset_escaped=$(escape_for_json "$using_powerset_content")
session_context="<EXTREMELY_IMPORTANT>\nPowerset is available.\n\n**Below is the full content of your 'powerset:using-powerset' skill - your introduction to using skills. For all other skills, use the 'Skill' tool:**\n\n${using_powerset_escaped}\n</EXTREMELY_IMPORTANT>"

# Output context injection as JSON.
# Claude Code hooks expect hookSpecificOutput.additionalContext (nested).
#
# Uses printf instead of heredoc to work around bash 5.3+ heredoc hang.
# See upstream issue 571.
printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context" | cat

exit 0
